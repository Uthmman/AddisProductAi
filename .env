# WooCommerce API credentials
WOOCOMMERCE_API_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
WOOCOMMERCE_SITE_URL=

# Google Search Console (optional)
# Create a service account in Google Cloud, enable Search Console API, and share access in GSC settings.
# Paste the private key directly, replacing newlines with \n.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GSC_SITE_URL=

# Google Picker (optional)
# Enable Google Picker API in Google Cloud and create an OAuth 2.0 Client ID and an API Key.
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Google AI Studio API Key
GOOGLE_API_KEY=
GEMINI_API_KEY=
WORDPRESS_AUTH_USER=
WORDPRESS_AUTH_PASS=